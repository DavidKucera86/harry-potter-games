{
  "name": "harry-potter-games",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "build:html": "node scripts/build-html.mjs",
    "build:js": "node scripts/build-js.mjs",
    "build": "npm run build:html && npm run build:js",
    "verify:build": "node scripts/verify-build.mjs",
    "prepare": "simple-git-hooks",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tests.json",
    "pretest": "npm run build && npm run lint && npm run typecheck",
    "test": "vitest run && playwright test",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:production": "PLAYWRIGHT_TARGET=production playwright test",
    "test:docker": "node scripts/test-docker.mjs",
    "test:ui": "playwright test --ui",
    "docs:test-catalog": "npm run build && playwright test --reporter=./scripts/gwt-catalog-reporter.ts",
    "lint": "eslint src/ tests/"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run verify:build && npm run lint && npm run typecheck && npm run docs:test-catalog && git add docs/E2E-TEST-CATALOG.md"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "happy-dom": "^16.8.1",
    "serve": "^14.2.4",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
